# LLM API configuration
# Copy this file to .env and fill in your values

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2
OPENAI_API_KEY=your-api-key-here

# Optional: override temperature (e.g. 1 for models that only support default)
# OPENAI_TEMPERATURE=1

# Faster models for quicker iteration (trade quality for speed):
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o

# Optional: Require API key for web /api/* routes. When set, clients must pass x-api-key header.
# API_KEY=your-secret-api-key
